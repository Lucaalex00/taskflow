{
  "ConnectionStrings": {
    "Postgres": "Host=localhost;Port=5432;Database=taskflow;Username=taskflow;Password=taskflow"
  },
  "LoadMonitor": {
    "IntervalSeconds": 60
  },
  "Jwt": {
    "Secret": "dev-only-secret-change-me-in-any-real-deployment-32chars+",
    "Issuer": "TaskFlow",
    "Audience": "TaskFlow",
    "ExpiryMinutes": 1440
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    }
  },
  "AllowedHosts": "*"
}
